/* Skspruce WIA3300-10 (MT7621AT + MT7615DN) */

#include "mt7621.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>

/ {
        compatible = "skspruce,wia3300-10", "mediatek,mt7621-soc";
        model = "Skspruce WIA3300-10";

        aliases {
                /* 系统LED状态别名 */
                led-boot = &led_boot;      // 启动状态 -> 红色LED
                led-failsafe = &led_boot;
                led-running = &led_power;  // 运行状态 -> 绿色LED (心跳模式)
                led-upgrade = &led_boot;
                ethernet0 = &gmac0;
                ethernet1 = &gmac1;
        };

        chosen {
                bootargs = "console=ttyS0,115200";
        };

        /* 256MB DDR3 RAM */
        memory@0 {
                device_type = "memory";
                reg = <0x0 0x10000000>;
        };

leds {
    compatible = "gpio-leds";

    /* ... 其他LED（boot, power, wan）定义保持不变 ... */

    /* 双色无线LED - 绿色部分：关联到2.4G射频 (phy0) */
    wlan2g_green {
        label = "wlan2g:green";
        gpios = <&gpio 4 GPIO_ACTIVE_HIGH>;
        /* 关键：添加默认触发器，让驱动自动管理 */
        linux,default-trigger = "phy0tpt";
    };

    /* 双色无线LED - 蓝色部分：关联到5G射频 (phy1) */
    wlan5g_blue {
        label = "wlan5g:blue";
        gpios = <&gpio 22 GPIO_ACTIVE_HIGH>;
        /* 关键：添加默认触发器，让驱动自动管理 */
        linux,default-trigger = "phy1tpt";
    };
};

        keys {
                compatible = "gpio-keys";

                /* 复位按键 (GPIO 18, 高电平有效) */
                reset {
                        label = "reset";
                        gpios = <&gpio 18 GPIO_ACTIVE_HIGH>;
                        linux,code = <KEY_RESTART>;
                };
        };
};

&spi0 {
        status = "okay";

        flash@0 {
                compatible = "jedec,spi-nor";
                reg = <0>;
                spi-max-frequency = <50000000>;

                partitions {
                        compatible = "fixed-partitions";
                        #address-cells = <1>;
                        #size-cells = <1>;

                        /* 严格遵循原厂MTD分区布局 */
                        partition@0 {
                                label = "u-boot";
                                reg = <0x000000 0x030000>;
                                read-only;
                        };

                        partition@30000 {
                                label = "u-boot-env";
                                reg = <0x030000 0x010000>;
                                read-only;
                        };

                        /* Factory分区：包含无线校准数据与MAC地址 */
                        partition@40000 {
                                label = "factory";
                                reg = <0x040000 0x010000>;
                                read-only;

                                nvmem-layout {
                                        compatible = "fixed-layout";
                                        #address-cells = <1>;
                                        #size-cells = <1>;

                                        /* MT7615DN EEPROM数据 */
                                        eeprom_factory_0: eeprom@0 {
                                                reg = <0x0 0x4da8>;
                                        };

                                        /* MAC地址偏移 (请根据原厂factory内容最终确认) */
                                        macaddr_factory_4: macaddr@4 {
                                                reg = <0x4 0x6>;
                                        };
                                        macaddr_factory_e000: macaddr@e000 {
                                                reg = <0xe000 0x6>;
                                        };
                                        macaddr_factory_e006: macaddr@e006 {
                                                reg = <0xe006 0x6>;
                                        };
                                };
                        };

                        partition@50000 {
                                label = "u-boot-backup";
                                reg = <0x050000 0x030000>;
                                read-only;
                        };

                        /* 主固件分区 (OpenWrt将刷写于此) */
                        partition@80000 {
                                compatible = "denx,uimage";
                                label = "firmware";
                                reg = <0x080000 0xf00000>;
                        };

                        /* 以下为原厂保留分区，OpenWrt通常不占用 */
                        partition@1000000 {
                                label = "firmware_backup";
                                reg = <0x1000000 0xf00000>;
                                read-only;
                        };
                        partition@1f00000 {
                                label = "boardinfo";
                                reg = <0x1f00000 0x010000>;
                                read-only;
                        };
                        partition@1f10000 {
                                label = "rebootcause";
                                reg = <0x1f10000 0x010000>;
                                read-only;
                        };
                };
        };
};

&pcie {
        status = "okay";
        bus-range = <0 255>;
        ranges;
};

&pcie0 {
        status = "okay";

        /* MT7615DN 5G WiFi */
        wifi@0,0 {
                reg = <0x0000 0 0 0 0>;
                compatible = "pci14c3,7662";
                nvmem-cells = <&eeprom_factory_0>, <&macaddr_factory_e006>;
                nvmem-cell-names = "eeprom", "mac-address";
                ieee80211-freq-limit = <5000000 6000000>;
        };
};

/* 网络交换芯片配置 - 端口顺序: W L L L L */
&switch0 {
        status = "okay";

        ports {
                #address-cells = <1>;
                #size-cells = <0>;

                port@0 {
                        reg = <0>;
                        label = "wan";
                        phy-mode = "rgmii";
                        phy-handle = <&ethphy0>;
                };

                port@1 {
                        reg = <1>;
                        label = "lan1";
                };

                port@2 {
                        reg = <2>;
                        label = "lan2";
                };

                port@3 {
                        reg = <3>;
                        label = "lan3";
                };

                port@4 {
                        reg = <4>;
                        label = "lan4";
                };

                /* CPU端口 */
                port@6 {
                        reg = <6>;
                        label = "cpu";
                        ethernet = <&gmac0>;
                        phy-mode = "rgmii";

                        fixed-link {
                                speed = <1000>;
                                full-duplex;
                                pause;
                        };
                };
        };
};

&gmac0 {
        status = "okay";
        nvmem-cells = <&macaddr_factory_4>;
        nvmem-cell-names = "mac-address";
        phy-mode = "rgmii";
};

&gmac1 {
        status = "okay";
        nvmem-cells = <&macaddr_factory_e000>;
        nvmem-cell-names = "mac-address";
        phy-mode = "rgmii";
        phy-handle = <&ethphy0>;
        label = "wan";
};

&mdio {
        ethphy0: ethernet-phy@0 {
                reg = <0>;
                phy-mode = "rgmii";
        };
};

&state_default {
        gpio {
                groups = "i2c", "jtag", "uart2", "uart3";
                function = "gpio";
        };
};
